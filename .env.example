# ── Database (Neon) ────────────────────────────────────────────────────────────
# Get from: neon.tech → your project → Connection string (pooled)
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Session ────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
SESSION_SECRET="replace-with-32-plus-char-random-string"
SESSION_COOKIE_NAME="fantasy_session"

# ── Cron Security ──────────────────────────────────────────────────────────────
# Vercel sends this automatically to cron routes as Bearer token
# Generate: openssl rand -hex 16
CRON_SECRET="replace-with-secret"

# ── App URL ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ── Stats Provider ─────────────────────────────────────────────────────────────
STATS_PROVIDER="mlb"
